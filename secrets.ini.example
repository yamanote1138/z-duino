; Copy this file to secrets.ini and fill in your values.
; secrets.ini is gitignored — never commit real credentials.
;
; Values are quoted as '"..."' (single quotes wrapping a double-quoted
; string) so PlatformIO's flag tokenizer keeps multi-word values (e.g.
; a railroad name with spaces) as a single argument.
[env]
build_flags =
    -D WIFI_SSID='"YourSSIDHere"'
    -D WIFI_PASS='"YourPasswordHere"'
    -D MDNS_HOSTNAME='"ztrain"'
    -D RAILROAD_NAME='"Z-Duino"'
    -D MAX_PWM=1000
    -D PWM_FREQ=20000
