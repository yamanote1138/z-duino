// WiFi credentials (required)
// The # is part of the syntax — do not remove it!
#define WIFI_SSID "YourSSIDHere"
#define WIFI_PASS "YourPasswordHere"

// mDNS hostname — your device will be reachable at http://<hostname>.local
#define MDNS_HOSTNAME "ztrain"

// Display name shown in the throttle UI header and browser tab
#define RAILROAD_NAME "Z-Duino"

// Maximum PWM output (0–1000). Controls the top speed of the train.
// 1000 = full 12V, 500 = ~6V, etc. Start low and increase to taste.
#define MAX_PWM 500

// WIFI_SSID and WIFI_PASS are required. The rest have sensible defaults.
